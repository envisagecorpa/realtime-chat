# Environment Configuration
NODE_ENV=development
PORT=3001

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# Database Configuration
DATABASE_URL=postgresql://chatuser:chatpass@localhost:5432/chatdb
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=chatdb
DATABASE_USER=chatuser
DATABASE_PASSWORD=chatpass

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=24h

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads
SERVE_STATIC_FILES=true
TUS_ENDPOINT=http://localhost:3001/tus
ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,text/plain,text/csv,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,video/mp4,video/webm,audio/mpeg,audio/wav

# Rate Limiting
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_REQUESTS=1000
UPLOAD_RATE_LIMIT_MAX=20

# Message Retention
MESSAGE_RETENTION_DAYS=30
ARCHIVE_CLEANUP_INTERVAL=daily

# Auto-moderation Configuration
AUTO_MODERATE_THRESHOLD=3

# Logging Configuration
LOG_LEVEL=info